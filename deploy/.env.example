# deploy/.env.example — copy to .env and fill in. NEVER commit the real .env.
# `docker compose` reads this (env_file + ${VAR} interpolation).

# --- TLS / reverse proxy ----------------------------------------------------
# Domain that points (A/AAAA record) at this host; Caddy gets a cert for it.
CONTROL_DOMAIN=control.example.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com
# Optional public IPFS read gateway domain (see caddy/Caddyfile).
# GATEWAY_DOMAIN=ipfs.example.com

# --- control API auth -------------------------------------------------------
# Shared secret the payments Worker sends as `Authorization: Bearer <token>` on
# POST /jobs. Generate a long random value, e.g.  openssl rand -hex 32
# Set the SAME value as the Worker secret PERSIST_CONTROL_TOKEN.
CONTROL_TOKEN=replace-with-a-long-random-token

# --- IPFS (kubo) ------------------------------------------------------------
# Public gateway used to build a previewable https URL for an ipfs:// ref.
IPFS_GATEWAY_PUBLIC=https://ipfs.io

# --- WebTorrent seeder ------------------------------------------------------
# wss:// trackers so the in-browser player can reach this seeder over WebRTC.
TRACKERS=wss://tracker.openwebtorrent.com,wss://tracker.webtorrent.dev

# --- Arweave bundler (optional) ---------------------------------------------
# To actually fund Arweave uploads server-side, point at an Irys/Turbo bundler
# you pre-fund and (if needed) a Bearer token. Leave empty → arweave jobs return
# `pending_backend` (use the client-funded path or a crypto rail instead).
# ARWEAVE_BUNDLER_URL=https://turbo.ardrive.io/tx
# ARWEAVE_BUNDLER_TOKEN=

# --- limits -----------------------------------------------------------------
# Largest staged upload accepted (bytes). Keep in sync with the Caddy max_size
# and the Worker's MAX_BYTES. Default 2 GiB.
MAX_BYTES=2147483648
