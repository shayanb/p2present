{
  "p2present": "1.0",
  "title": "Rage-Coding the Mother of All VPNs — Berlin 2026 (PDF deck)",
  "_comment": "Second demo — exercises the pdf.js deck adapter (deck.type \"pdf\"). Same 23-page deck and same talk video + timing as the HTML demo (../demo/manifest.json), but the slides are rendered from a PDF instead of an HTML <deck-stage>. Times are float SECONDS.",
  "meta": {
