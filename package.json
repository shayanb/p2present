{
  "name": "p2present",
  "version": "0.1.0",
  "private": true,
  "description": "Forkable web app for hosting presentation pages where slides and a talk video play back in sync.",
  "type": "module",
  "scripts": {
    "dev": "node --version >/dev/null && npx --yes serve docs -l 5173",
    "preview": "wrangler dev",
    "test": "node scripts/test.mjs && node --test \"service/test/*.test.mjs\"",
    "test:app": "node scripts/test.mjs",
    "test:service": "node --test \"service/test/*.test.mjs\"",
    "smoke": "node scripts/smoke.mjs",
    "import-chapters": "node scripts/import-chapters.mjs",
    "deploy": "wrangler deploy"
  },
  "license": "MIT",
  "homepage": "https://p2present.com/",
  "devDependencies": {
    "playwright": "1.61.1",
    "wrangler": "^4.113.0"
  }
}
