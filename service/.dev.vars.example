# .dev.vars.example — local dev config for `wrangler dev`.
# Copy to `.dev.vars` (gitignored) and fill in. Production values use
# `wrangler secret put` / the dashboard instead — never commit real tokens.

# Enable the optional IPFS mirror on save:
# IPFS_PIN=true
# IPFS_PIN_TOKEN=your-pinata-jwt-here
# IPFS_PIN_ENDPOINT=https://api.pinata.cloud/pinning/pinJSONToIPFS

# Override the player redirect target / CORS origin if needed:
# APP_BASE=http://127.0.0.1:5173/app/
# ALLOW_ORIGIN=*
